# PostgreSQL
DATABASE_URL=postgresql://jfight:senha@localhost:5432/jfight

# JWT (gere uma chave longa em produção)
JWT_SECRET=troque-por-uma-chave-segura-de-64-caracteres-minimo
JWT_EXPIRES_IN=30d

# Servidor
PORT=3000
PUBLIC_URL=https://api.seudominio.com.br

# Upload de fotos (servidas em /uploads/fotos/...)
UPLOAD_DIR=./uploads

# Google OAuth (mesmo Web Client ID do app)
GOOGLE_CLIENT_ID=276798866114-xxxx.apps.googleusercontent.com

# Admin inicial (criado no primeiro boot se não existir)
ADMIN_EMAIL=admin@jfight.app
ADMIN_PASSWORD=Demo@2026
ADMIN_NOME=Administrador J FIGHT
